<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="mail_template_property_sold" model="mail.template">
        <field name="name">Property Sold</field>
        <field name="model_id" ref="real_estate.model_property_property"/>
        <field name="subject">Sold! {{ object.name }}</field>
        <field name="email_to">{{ object.email }}</field>
        <field name="body_html" type="html">
            <div class="m-3">
                Hi {{object.customer.name}},
                <br/>
                <h1>Congratulations!</h1>
                <br/>
                <br/>
                <p>
                    Your property [{{object.name}}] has been successfully sold..
                </p>
            </div>
        </field>
        <field name="auto_delete" eval="False"/>
    </record>
</odoo>



