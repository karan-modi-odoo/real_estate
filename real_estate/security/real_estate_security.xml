<odoo>
    <data>

        <record model="ir.module.category" id="module_category_real_estate">
            <field name="name">Real Estate</field>
            <field name="sequence">40</field>
        </record>

        <record id="group_real_estate_agent" model="res.groups">
            <field name="name">Agent</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="category_id" ref="real_estate.module_category_real_estate"/>
        </record>

        <record id="group_real_estate_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="implied_ids" eval="[(4, ref('real_estate.group_real_estate_agent'))]"/>
            <field name="category_id" ref="real_estate.module_category_real_estate"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <record id="rule_real_estate_property_agent" model="ir.rule">
            <field name="name">Agent: only own records</field>
            <field name="model_id" ref="model_property_property"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('real_estate.group_real_estate_agent'))]"/>
        </record>


        <record id="rule_real_estate_property_manager" model="ir.rule">
            <field name="name">Manager: all records</field>
            <field name="model_id" ref="model_property_property"/>
            <field name="domain_force">[(1, '=',1)]</field>
            <field name="groups" eval="[(4, ref('real_estate.group_real_estate_manager'))]"/>
        </record>
    </data>
</odoo>
