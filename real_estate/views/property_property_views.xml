<odoo>
    <data>

        <record model="ir.ui.view" id="property_property_view_tree">
            <field name="name">property.property.view.tree</field>
            <field name="model">property.property</field>
            <field name="arch" type="xml">
                <list decoration-success="resell == True" decoration-danger="resell == False">
                    <field name="name"/>
                    <field name="type"/>
                    <field name="customer"/>
                    <field name="address"/>
                    <field name="price"/>
                    <field name="area"/>
                    <field name="resell" widget="badge" optional="required"/>
                    <field name="register_date"/>
                    <field name="age"/>
                    <field name="description" widget="html" optional="hide"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="property_property_view_form">
            <field name="name">property.property.view.form</field>
            <field name="model">property.property</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" type="object" name="action_mark_sold" icon="fa-user" invisible="state == 'sold'">
                                <field string="Mark as Sold" name="property_count" widget="statinfo"/>
                            </button>
                        </div>

                        <group col="4" class="o_group o_group_col_4">

                            <group string="Basic Property Info" col="2" class="o_group o_inner_group o_border">
                                <field name="name"/>
                                <field name="type"/>
                                <field name="state"/>
                                <field name="resell"/>
                            </group>

                            <group string="Customer and Contact" col="2" class="o_group o_inner_group o_border">
                                <field name="customer"/>
                                <field name="email"/>
                                <field name="address" nolabel="0"/>
                            </group>

                            <group string="Structure and Dimensions" col="2" class="o_group o_inner_group o_border">
                                <field name="elevator"/>
                                <field name="floor" invisible="type != 'flat' and type != 'apartment'"/>
                                <field name="width"/>
                                <field name="height"/>
                                <field name="area"/>
                            </group>

                            <group string="Pricing and Sales Info" col="2" class="o_group o_inner_group o_border">
                                <field name="price"/>
                                <field name="register_date"/>
                                <field name="sales_person" widget="many2many_tags"/>
                                <field name="age"/>
                            </group>

                            <group string="Description and Images" col="2" class="o_group o_inner_group o_border">
                                <field name="image" widget="image"/>
                                <field name="description" widget="html" nolabel="0"/>
                            </group>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="property_property_view_search">
            <field name="name">property.property.view.search</field>
            <field name="model">property.property</field>
            <field name="arch" type="xml">
                <search string="Search Property">
                    <field name="name" string="Property"/>
                    <field name="customer"/>
                    <filter name="resell" string="Resell" domain="[('resell','=','true')]"/>
                    <filter name="not_resell" string="Not Resell" domain="[('resell','=','false')]"/>
                    <filter name="age" string="Age" domain="[('age','>',5)]"/>
                    <filter name="price" string="Price" domain="[('price','>',10000000)]"/>
                    <filter name="today_registered_property" string="Today's Registered Property" domain="[('register_date','=',datetime.date.today())]"/>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="property_property_main_action">
            <field name="name">Property</field>
            <field name="res_model">property.property</field>
            <field name="view_mode">list,kanban,form</field>
        </record>

        <menuitem name="Real Estate" id="real_estate_root_menu"/>

        <menuitem name="Property" id="real_estate_property_menu"
                  parent="real_estate.real_estate_root_menu"
                  action="real_estate.property_property_main_action"/>

    </data>
</odoo>



